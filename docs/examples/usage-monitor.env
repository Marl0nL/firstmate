# Example config/usage-monitor.env - copy into this home's config/ to opt in.
#
# The token-usage monitor is INERT by default: with no config/usage-monitor.env
# (or FM_USAGE_ENABLED unset/0) firstmate polls nothing automatically and the
# session digest surfaces no quota line. fm-usage-poll.sh and fm-usage-report.sh
# can still be run by hand at any time. See docs/usage-monitor.md for the full
# design, the transcript schema, and the /api/oauth/usage wire format.
#
# This file is parsed key by key (never sourced/executed) and is gitignored. Any
# key here is also overridable by an environment variable of the same name.

# Master opt-in: arm the watcher check shim (state/usage-watch.check.sh), run the
# session-start backfill, and surface the quota line in the digest.
FM_USAGE_ENABLED=1

# Let the dispatch guard advise holds and let the poll emit a quota-severity wake.
# Advisory only - it never hard-blocks an explicit captain dispatch.
FM_USAGE_GUARD_ENABLED=1

# Percent high-water for both the hold decision and the wake threshold (1..100).
FM_USAGE_HIGH_WATER=80

# Seconds a cached quota.json is still trusted before it is treated as stale.
FM_USAGE_QUOTA_TTL=900

# Relative report weights per token class (a ranking heuristic, not the
# subscription's server-side limit accounting). May be fractional.
FM_USAGE_WEIGHT_INPUT=1
FM_USAGE_WEIGHT_OUTPUT=5
FM_USAGE_WEIGHT_CACHE_CREATION=1.25
FM_USAGE_WEIGHT_CACHE_READ=0.1

# Conservative ceilings for the ledger burn-rate heuristic used only when the
# live quota endpoint is unreachable (weighted tokens; percent is ESTIMATED).
FM_USAGE_EST_5H_CEILING=40000000
FM_USAGE_EST_WEEKLY_CEILING=400000000
