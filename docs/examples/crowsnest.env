# Example Crowsnest config. Copy to config/crowsnest.env (local, gitignored) and
# run: bin/fm-crowsnest.sh enable
#
# Presence + a truthy CROWSNEST_ENABLED is the whole opt-in. Everything else is
# optional; sensible defaults are resolved at runtime. See docs/crowsnest.md.

# Turn the Crowsnest on. Absent or falsey keeps it fully inert.
CROWSNEST_ENABLED=1

# The agent name people target from Chat (/local-agents <name>: <prompt>).
# Defaults to firstmate.
# CROWSNEST_AGENT_NAME=firstmate

# The immediate async acknowledgement posted back to Chat while firstmate
# composes the real reply.
# CROWSNEST_ACK=On it, captain - firstmate is on the bridge and will report back shortly.

# Override the local-agents(-chat) CLI. Resolved automatically otherwise
# (prefers local-agents-chat, falls back to local-agents).
# CROWSNEST_LA_CLI=/path/to/local-agents-chat

# The backend config.toml (registry + GCP credentials). Uses the backend default
# (~/.config/local-agents/config.toml) when unset.
# CROWSNEST_LA_CONFIG=/home/you/.config/local-agents/config.toml

# Override the interpreter that imports the backend for posting. Resolved from
# the CLI's own shebang otherwise.
# CROWSNEST_PYTHON=/path/to/python

# Testing only: record would-be posts to state/chat-outbox/ instead of sending.
# CROWSNEST_DRY_RUN=1
